{
  "name": "@matthesketh/fleet-secrets-client",
  "version": "0.1.0",
  "description": "Client library for fleet-secrets-agent v2 — fetches secrets over a Unix socket",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "test": "vitest run"
  },
  "engines": { "node": "20" },
  "license": "MIT",
  "author": "Matt Hesketh <matt@heskethwebdesign.co.uk>",
  "repository": {
    "type": "git",
    "url": "https://github.com/wrxck/fleet.git",
    "directory": "packages/fleet-secrets-client"
  },
  "keywords": ["fleet", "secrets", "vault", "unix-socket"],
  "devDependencies": {
    "tsup": "8.5.1",
    "vitest": "4.0.18",
    "typescript": "5.6.3"
  }
}
